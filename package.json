{
  "name": "vetter",
  "version": "0.5.2",
  "description": "Pre-install risk scanner for npm packages",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "vetter": "./bin/vetter"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts",
    "dev": "tsup src/cli.ts --format esm --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm test -- --run"
  },
  "keywords": [
    "npm",
    "security",
    "audit",
    "cli",
    "scanner"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/founder-guy/vetter.git"
  },
  "bugs": {
    "url": "https://github.com/founder-guy/vetter/issues"
  },
  "homepage": "https://github.com/founder-guy/vetter#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "nanospinner": "^1.2.2",
    "npm-pick-manifest": "^11.0.1",
    "npm-registry-fetch": "^19.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "semantic-release": "^24.2.9",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ]
}
