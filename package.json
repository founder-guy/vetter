{
  "name": "vetter",
  "version": "1.1.4",
  "description": "Pre-install risk scanner for npm packages",
  "type": "module",
  "main": "dist/cli.mjs",
  "bin": {
    "vetter": "./bin/vetter"
  },
  "scripts": {
    "build": "tsdown src/cli.ts --dts",
    "dev": "tsdown src/cli.ts --watch",
    "test": "vitest",
    "lint": "eslint src __tests__",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm test -- --run"
  },
  "keywords": [
    "npm",
    "security",
    "audit",
    "cli",
    "scanner"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/founder-guy/vetter.git"
  },
  "bugs": {
    "url": "https://github.com/founder-guy/vetter/issues"
  },
  "homepage": "https://github.com/founder-guy/vetter#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "nanospinner": "^1.2.2",
    "npm-pick-manifest": "^11.0.1",
    "npm-registry-fetch": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^18.19.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.2.4",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ]
}
